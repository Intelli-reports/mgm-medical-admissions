DirectoryIndex index.html

# ============================================================
# SPA routing — serve index.html for all routes
# ============================================================
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule . - [L]
  RewriteRule . /index.html [L]
</IfModule>

# ============================================================
# PERFORMANCE: Gzip compression (saves 68-82% on JS/CSS)
# Most Apache hosts have mod_deflate enabled by default
# ============================================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# Brotli (better than gzip, supported by modern hosts)
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/css text/plain
  AddOutputFilterByType BROTLI_COMPRESS application/javascript application/json
  AddOutputFilterByType BROTLI_COMPRESS image/svg+xml
</IfModule>

# ============================================================
# PERFORMANCE: Long-term caching for Vite hashed assets
# Vite adds a content hash to every filename (e.g. vendor-react-BPXSdIuW.js)
# so these files NEVER change — safe to cache for 1 year
# ============================================================
<IfModule mod_expires.c>
  ExpiresActive On

  # Hashed JS/CSS bundles — 1 year (filename changes on update)
  ExpiresByType application/javascript   "access plus 1 year"
  ExpiresByType text/css                 "access plus 1 year"

  # Images — 1 year
  ExpiresByType image/webp               "access plus 1 year"
  ExpiresByType image/png                "access plus 1 year"
  ExpiresByType image/jpeg               "access plus 1 year"
  ExpiresByType image/svg+xml            "access plus 1 year"
  ExpiresByType image/x-icon             "access plus 1 year"

  # Fonts — 1 year
  ExpiresByType font/woff2               "access plus 1 year"
  ExpiresByType font/woff                "access plus 1 year"

  # HTML — 1 hour (needs to pick up new deployments quickly)
  ExpiresByType text/html                "access plus 1 hour"
</IfModule>

# Immutable flag for hashed Vite assets (tells browser: never recheck)
<IfModule mod_headers.c>
  <FilesMatch "\.[0-9a-f]{8}\.(js|css)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # WebP images
  <FilesMatch "\.(webp|png|jpg|jpeg|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000"
  </FilesMatch>
  # HTML — no cache for SPA shell
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

